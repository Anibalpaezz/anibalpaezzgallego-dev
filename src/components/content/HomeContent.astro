---
import { t } from "@/lib/t";

export interface Props {
  lang: "es" | "en" | "fr" | "de" | "zh";
}

const { lang } = Astro.props;

const features = [
  { icon: "database", title: t(lang, "features.cleanCode.title"), desc: t(lang, "features.cleanCode.description") },
  { icon: "layers", title: t(lang, "features.modernDesign.title"), desc: t(lang, "features.modernDesign.description") },
  { icon: "graduation", title: t(lang, "features.performance.title"), desc: t(lang, "features.performance.description") },
];
---

<section class="relative min-h-screen flex items-center overflow-hidden">
  <div class="hero-mesh-bg" />
  <div class="hero-grid-overlay" />
  <div class="relative z-10 w-full">
    <div class="container mx-auto px-4 md:px-8 py-24 md:py-32">
      <div class="max-w-4xl mx-auto text-center animate-fade-in">
        <div class="flex justify-center mb-8">
          <span
            class="badge-open-to-work inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-sm font-medium tracking-wide"
            style="background-color:#ffc1008c;border-width:1px;border-style:solid;border-color:#ffc100;color:rgb(255,204,0)"
          >
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-yellow-400 opacity-75" />
              <span class="relative inline-flex rounded-full h-2 w-2 bg-yellow-500" />
            </span>
            Currently working at<span class="font-semibold ml-1">
              <span style="background:linear-gradient(to right,#ffffff,#41C0CF);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">Arktic</span>
              <span class="text-gray-400 mx-1">|</span>
              <span style="background:linear-gradient(to right,#001391,#14549C);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">BBVA CIB</span>
            </span>
          </span>
        </div>

        <p class="text-base md:text-lg text-muted-foreground mb-3 tracking-widest uppercase font-medium">{t(lang, "hero.greeting")}</p>

        <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold mb-6 tracking-tighter leading-none" style="letter-spacing:-0.04em">
          <span class="gradient-text">Anibal Paez</span><br />
          <span class="gradient-text">Gallego</span>
        </h1>

        <h2 class="text-base sm:text-lg md:text-xl text-foreground/70 mb-10 font-normal tracking-tight max-w-lg mx-auto">
          {t(lang, "hero.subtitle")}
        </h2>

        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href={lang === "es" ? "/projects" : `/${lang}/projects`}
            class="inline-flex items-center justify-center rounded-lg bg-gradient-primary hover:opacity-90 transition-all duration-200 shadow-glow px-8 py-3 text-sm font-medium text-white"
          >
            {t(lang, "hero.cta")}
            <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
          </a>
          <a
            href={lang === "es" ? "/contact" : `/${lang}/contact`}
            class="inline-flex items-center justify-center rounded-lg border border-border/60 hover:border-primary/50 transition-colors duration-200 px-8 py-3 text-sm font-medium"
          >
            {t(lang, "hero.contact")}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="py-16 md:py-24 bg-background">
  <div class="container mx-auto px-4 md:px-8">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-5">
      {features.map((f, i) => (
        <div
          class="rounded-xl border border-border/50 hover:border-primary/30 hover:shadow-lg transition-all duration-300 hover:-translate-y-1 animate-slide-up bg-card/60 backdrop-blur-sm p-6"
          style={`animation-delay:${i * 0.1}s`}
        >
          <div class="w-10 h-10 bg-gradient-primary rounded-lg flex items-center justify-center mb-4">
            {f.icon === "database" && (
              <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" /></svg>
            )}
            {f.icon === "layers" && (
              <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
            )}
            {f.icon === "graduation" && (
              <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 14l9-5-9-5-9 5 9 5z" /><path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" /></svg>
            )}
          </div>
          <h3 class="text-lg font-semibold mb-2 tracking-tight">{f.title}</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="py-16 md:py-24 bg-card/40">
  <div class="container mx-auto px-4 md:px-8 text-center">
    <h2 class="text-3xl md:text-4xl font-bold mb-4 tracking-tight">{t(lang, "work_together.title")}</h2>
    <p class="text-base text-muted-foreground mb-8 max-w-xl mx-auto leading-relaxed">{t(lang, "work_together.description")}</p>
    <a
      href={lang === "es" ? "/contact" : `/${lang}/contact`}
      class="inline-flex items-center justify-center rounded-lg bg-gradient-accent hover:opacity-90 transition-opacity px-8 py-3 text-sm font-medium text-white"
    >
      {t(lang, "work_together.button")}
      <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
    </a>
  </div>
</section>
