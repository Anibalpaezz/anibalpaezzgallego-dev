---
import { t, allLangs, langName } from "@/lib/t";

export interface Props {
  lang: "es" | "en" | "fr" | "de" | "zh";
}

const { lang } = Astro.props;
const path = Astro.url.pathname;
const cleanPath = path.replace(/^\/(en|fr|de|zh)/, "") || "/";

const navItems = [
  { href: "/", i18nKey: "navBar.home" },
  { href: "/about", i18nKey: "navBar.about" },
  { href: "/projects", i18nKey: "navBar.projects" },
  { href: "/resume", i18nKey: "navBar.resume" },
  { href: "/blog", i18nKey: "navBar.blog" },
  { href: "/contact", i18nKey: "navBar.contact" },
];

function localHref(p: string): string {
  return lang === "es" ? p : `/${lang}${p}`;
}

function isActive(itemPath: string): boolean {
  if (itemPath === "/") return cleanPath === "/";
  return cleanPath.startsWith(itemPath);
}
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-background/80 backdrop-blur-md border-b border-border">
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <a href={localHref("/")} class="text-xl font-bold gradient-text">
        Portfolio
      </a>

      <div class="hidden md:flex items-center space-x-1">
        {navItems.map((item) => (
          <a
            href={localHref(item.href)}
            class:list={[
              "px-4 py-2 rounded-lg transition-colors",
              isActive(item.href)
                ? "bg-primary text-primary-foreground"
                : "hover:bg-secondary",
            ]}
          >
            {t(lang, item.i18nKey)}
          </a>
        ))}
      </div>

      <div class="hidden md:flex items-center space-x-2">
        <button
          id="theme-toggle-desktop"
          onclick="window.__toggleTheme()"
          class="p-2 rounded-lg hover:bg-secondary transition-colors"
          aria-label="Toggle theme"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path class="dark:hidden" stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            <path class="light:hidden" stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
        </button>

        <div class="relative group">
          <button
            class="p-2 rounded-lg hover:bg-secondary transition-colors flex items-center gap-1"
            aria-label="Change language"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </button>
          <div class="absolute right-0 mt-1 w-40 rounded-lg border border-border bg-card shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50">
            <div class="py-1">
              {allLangs().map((l) => (
                <a
                  href={l === "es" ? "/" : `/${l}${cleanPath === "/" ? "" : cleanPath}`}
                  class:list={[
                    "block px-4 py-2 text-sm transition-colors",
                    l === lang ? "bg-primary/10 text-primary font-medium" : "hover:bg-secondary",
                  ]}
                >
                  {langName(l)} {l === lang ? "✓" : ""}
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>

      <div class="md:hidden flex items-center space-x-2">
        <button
          id="theme-toggle-mobile"
          onclick="window.__toggleTheme()"
          class="p-2 rounded-lg hover:bg-secondary transition-colors"
          aria-label="Toggle theme"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path class="dark:hidden" stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            <path class="light:hidden" stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
        </button>

        <button
          id="menu-btn"
          onclick="window.__toggleMenu()"
          class="p-2 rounded-lg hover:bg-secondary transition-colors"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <svg id="menu-icon-open" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="menu-icon-close" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <div id="mobile-menu" class="hidden md:hidden py-4 animate-fade-in">
      <div class="flex flex-col space-y-2">
        {navItems.map((item) => (
          <a
            href={localHref(item.href)}
            class:list={[
              "px-4 py-3 rounded-lg transition-colors",
              isActive(item.href)
                ? "bg-primary text-primary-foreground"
                : "hover:bg-secondary",
            ]}
          >
            {t(lang, item.i18nKey)}
          </a>
        ))}
        <div class="flex items-center gap-2 px-4 pt-2">
          {allLangs().map((l) => (
            <a
              href={l === "es" ? "/" : `/${l}${cleanPath === "/" ? "" : cleanPath}`}
              class:list={[
                "px-3 py-1.5 text-sm rounded-lg border transition-colors",
                l === lang
                  ? "bg-primary text-primary-foreground border-primary"
                  : "border-border hover:bg-secondary",
              ]}
            >
              {l.toUpperCase()}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</nav>
